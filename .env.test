# Environment for the e2e stack only. The DB points at the throwaway docker
# Postgres (docker-compose.e2e.yml), never at Neon. Secrets here are dummies —
# nothing in the study-mode suite calls Google, Anthropic or Resend.
NODE_ENV=test
DATABASE_URL=postgresql://e2e:e2e@127.0.0.1:55432/video_course_e2e
DIRECT_DATABASE_URL=postgresql://e2e:e2e@127.0.0.1:55432/video_course_e2e
BETTER_AUTH_SECRET=e2e-test-secret-not-for-production-use-only
BETTER_AUTH_URL=http://localhost:3009
NEXT_PUBLIC_APP_URL=http://localhost:3009
GOOGLE_CLIENT_ID=e2e-dummy-google-client-id
GOOGLE_CLIENT_SECRET=e2e-dummy-google-client-secret
ANTHROPIC_API_KEY=e2e-dummy-anthropic-key
OWNER_EMAIL=e2e@videocourse.test
CRON_SECRET=e2e-dummy-cron-secret
