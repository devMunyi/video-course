# Copy to .env.test (gitignored) to run the e2e suite. All values are local-only
# dummies — the study-mode specs never call Google, Anthropic or Resend. The one
# rule: BETTER_AUTH_SECRET must be identical here and in e2e/seed.ts's environment,
# because the seed signs the session cookie with it and the app verifies it.
NODE_ENV=test
DATABASE_URL=postgresql://e2e:e2e@127.0.0.1:55432/video_course_e2e
DIRECT_DATABASE_URL=postgresql://e2e:e2e@127.0.0.1:55432/video_course_e2e
BETTER_AUTH_SECRET=set-any-fixed-local-string-here
BETTER_AUTH_URL=http://localhost:3009
NEXT_PUBLIC_APP_URL=http://localhost:3009
GOOGLE_CLIENT_ID=dummy
GOOGLE_CLIENT_SECRET=dummy
ANTHROPIC_API_KEY=dummy
OWNER_EMAIL=e2e@videocourse.test
CRON_SECRET=dummy
